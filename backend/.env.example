# NEDAF Environment Configuration
# Copy this file to .env and fill in your values

# OpenAI API Key (required for LLM features)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# Vector store directory for LLM embeddings (optional)
# Default: .cache/vectorstore
# NEDAF_VECTOR_STORE=/path/to/vectorstore

# Directory containing reference books/documents for LLM (optional)
# Default: data/books
# NEDAF_BOOKS_DIR=/path/to/books

# Log file location (optional)
# Default: logs/nedaf.log
# NEDAF_LOGS=/path/to/nedaf.log

# Number of document chunks to use for LLM context (optional)
# Default: 4
# NEDAF_LLM_CHUNKS=4
